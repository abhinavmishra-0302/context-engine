{
  "title": "RAG Query Analytics",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Queries / min",
      "targets": [
        {
          "expr": "rate(rag_queries_total[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Average LLM Duration (ms)",
      "targets": [
        {
          "expr": "rate(llm_duration_ms_sum[5m]) / rate(llm_duration_ms_count[5m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
