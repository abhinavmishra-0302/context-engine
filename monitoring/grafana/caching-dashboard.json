{
  "title": "RAG Caching",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "targets": [
        {
          "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Used Memory",
      "targets": [
        {
          "expr": "redis_memory_used_bytes"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
